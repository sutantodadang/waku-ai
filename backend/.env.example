# Waku Backend Configuration

# ── Platform WhatsApp number ─────────────────────────────────────────────
# Waku's OWN number — used for the reverse-OTP / system channel (not a tenant).
WHATSAPP_TOKEN=your_platform_meta_token
PLATFORM_PHONE_NUMBER_ID=your_platform_phone_number_id
VERIFY_TOKEN=waku_verify_123
APP_SECRET=your_meta_app_secret

# ── Services ─────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
DATABASE_URL=sqlite+aiosqlite:///./waku.db

# ── Security (REQUIRED in production) ────────────────────────────────────
# Fernet key that encrypts each business's WhatsApp access_token at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
# Secret for signing dashboard JWTs — use a long random string (>= 32 chars).
JWT_SECRET=
JWT_EXPIRE_HOURS=168

# ── Meta Embedded Signup (Scope B — fill after App Review) ───────────────
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
