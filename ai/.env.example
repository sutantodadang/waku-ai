# Waku AI Service — Environment Configuration
# Copy this to .env and fill in your values.

# OpenAI-compatible API (set to OpenRouter for cloud, or a local server for llamacpp/MLz)
OPENAI_API_KEY=your_openrouter_api_key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=cohere/north-mini-code:free

# Vision model (for image-matching). Defaults to LLM_MODEL when unset.
VISION_MODEL=cohere/north-mini-code:free

# Embeddings — can point at a different provider/endpoint than the chat model
EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
# EMBED_BASE_URL=   # defaults to OPENAI_BASE_URL when unset
# EMBED_API_KEY=    # defaults to OPENAI_API_KEY when unset
EMBED_INPUT_FORMAT=openrouter   # "openrouter" (content-array) or "openai" (plain strings)

# Optional OpenRouter ranking headers
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Waku

# Ollama (local LLM fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# LLM Provider: "auto" (try OpenAI → Ollama), "openai", or "ollama"
LLM_PROVIDER=openai

# Service
AI_SERVICE_PORT=8001

# Conversation
MAX_CONTEXT_MESSAGES=20

# Shared secret the backend must send as X-Waku-Secret. Leave empty to disable
# auth (dev only). In production set the SAME value here and in backend/.env.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
AI_SERVICE_SECRET=
