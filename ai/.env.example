# Waku AI Service — Environment Configuration
# Copy this to .env and fill in your values.

# OpenAI-compatible API (optional — leave blank to use Ollama)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Ollama (local LLM fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# LLM Provider: "auto" (try OpenAI → Ollama), "openai", or "ollama"
LLM_PROVIDER=auto

# Service
AI_SERVICE_PORT=8001

# Conversation
MAX_CONTEXT_MESSAGES=20
